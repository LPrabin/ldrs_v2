# ── Default LLM Provider ──────────────────────────────────────────
# Which provider to use: "local", "openai", or "gemini"
LLM_PROVIDER = "local"

# ── Local Provider (OpenAI-compatible, e.g. gpu-router / qwen3-vl) ──
LOCAL_API_KEY = "random"
LOCAL_BASE_URL = "link"
LOCAL_MODEL = ""

# Backward-compat aliases (used if LOCAL_* not set)
API_KEY = "random"
BASE_URL = "link"
CHATGPT_API_KEY = "random"

# ── OpenAI Provider ──────────────────────────────────────────────
OPENAI_API_KEY = "dummy"
OPENAI_MODEL = "gpt-4o-mini"

# ── Google Gemini Provider ───────────────────────────────────────
GEMINI_API_KEY = "key"
GEMINI_MODEL = "gemini/gemini-2.5-flash"
